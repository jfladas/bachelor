{
  "name": "amorphous-blob",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run vue\" \"npm run electron\"",
    "vue": "vite",
    "electron": "electron electron/main.cjs",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "generate:icns": "sh scripts/generate_icns.sh"
  },
  "dependencies": {
    "flubber": "^0.4.2",
    "fs-extra": "^11.3.4",
    "matter-js": "^0.20.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "electron": "^34.0.2",
    "electron-builder": "^24.6.0",
    "vite": "^6.0.5"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.yourname.amorphous-blob",
    "productName": "Amorphous Blob",
    "directories": {
      "buildResources": "public",
      "output": "dist_electron"
    },
    "files": [
      "dist/**",
      "electron/**",
      "node_modules/**",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "electron/assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "electron/assets/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/assets/icon.ico",
      "uninstallerIcon": "electron/assets/icon.ico"
    }
  }
}