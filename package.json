{
  "name": "bachelor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run vue\" \"npm run electron\"",
    "vue": "vite",
    "electron": "electron electron/main.cjs",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder"
  },
  "dependencies": {
    "flubber": "^0.4.2",
    "matter-js": "^0.20.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "electron": "^34.0.2",
    "electron-builder": "^24.6.0",
    "vite": "^6.0.5"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.yourname.bachelor",
    "productName": "Bachelor",
    "directories": {
      "buildResources": "public",
      "output": "dist_electron"
    },
    "files": [
      "dist/**",
      "electron/**",
      "node_modules/**",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}
